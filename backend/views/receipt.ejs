<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Payment Receipt</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:#f3f6fb;
padding:35px;
}

.receipt{

width:800px;

margin:auto;

background:white;

border-radius:12px;

overflow:hidden;

box-shadow:0 5px 20px rgba(0,0,0,.15);

}

.header{

background:#0F4C81;

color:white;

padding:30px 35px;

display:flex;

justify-content:space-between;

align-items:flex-start;

}

.company{

display:flex;

gap:20px;

align-items:flex-start;

}

.logo{

width:70px;

height:70px;

border-radius:10px;

background:white;

display:flex;

align-items:center;

justify-content:center;

overflow:hidden;

}

.logo img{

width:65px;

}

.company-name{

font-size:28px;

font-weight:bold;

margin-bottom:6px;

}

.tagline{

font-size:13px;

opacity:.9;

margin-bottom:10px;

}

.address{

font-size:13px;

line-height:20px;

}

.status{

text-align:right;

}

.status h3{

font-size:13px;

margin-bottom:10px;

}

.paid{

display:inline-block;

background:#16a34a;

padding:10px 22px;

border-radius:30px;

font-size:18px;

font-weight:bold;

}

.title{

padding:30px;

text-align:center;

border-bottom:1px solid #eee;

}

.title h1{

font-size:34px;

color:#0F4C81;

letter-spacing:1px;

}

/* ============================= */

.info-section{

display:flex;

justify-content:space-between;

padding:25px 30px;

background:#F8FAFC;

border-bottom:1px solid #E5E7EB;

}

.info-card{

width:23%;

}

.label{

font-size:13px;

color:#6B7280;

margin-bottom:8px;

font-weight:bold;

}

.value{

font-size:15px;

font-weight:600;

color:#111827;

}

.status-paid{

display:inline-block;

background:#DCFCE7;

color:#15803D;

padding:6px 14px;

border-radius:20px;

font-size:13px;

font-weight:bold;

}

.grid{

display:grid;

grid-template-columns:1fr 1fr;

gap:25px;

padding:30px;

}

.card{

border:1px solid #E5E7EB;

border-radius:10px;

padding:20px;

}

.card h2{

color:#0F4C81;

margin-bottom:18px;

font-size:20px;

}

.card table{

width:100%;

border-collapse:collapse;

}

.card td{

padding:10px 0;

border-bottom:1px solid #F1F5F9;

font-size:14px;

}

.card td:first-child{

color:#6B7280;

width:40%;

}

.amount{

font-size:24px;

color:#16A34A;

}

/* ================================= */

.footer{

margin:30px;

border-top:2px solid #E5E7EB;

padding-top:25px;

}

.footer-grid{

display:grid;

grid-template-columns:1fr 1fr 1fr;

gap:30px;

}

.footer-grid h3{

color:#0F4C81;

font-size:18px;

margin-bottom:12px;

}

.footer-grid p{

font-size:13px;

line-height:22px;

color:#4B5563;

}

.footer-note{

margin-top:30px;

padding-top:18px;

border-top:1px solid #E5E7EB;

text-align:center;

font-size:12px;

color:#6B7280;

}

/* ================================= */
/* Print */
/* ================================= */

@page{

size:A4;

margin:20mm;

}

@media print{

body{

background:white;

padding:0;

}

.receipt{

width:100%;

box-shadow:none;

border-radius:0;

}

}

@media print {
  .print-hide {
    display: none !important;
  }

  body {
    background: white !important;
  }

  .receipt-container {
    box-shadow: none !important;
    margin: 0;
    width: 100%;
  }
}

</style>

</head>

<body>

<div class="receipt">

<div class="header">

<div class="company">

<div class="logo">

<% if(settings.logo){ %>

<img src="<%= settings.logo %>">

<% } %>

</div>

<div>

<div class="company-name">

<%= settings.businessName %>

</div>

<div class="tagline">

<%= settings.tagline %>

</div>

<div class="address">

<%= settings.address %><br>

☎ <%= settings.phone1 %><br>

✉ <%= settings.email %><br>

🌐 <%= settings.website %>

</div>

</div>

</div>

<div class="status">

<h3>Payment Status</h3>

<div class="paid">

✓ PAID

</div>

</div>

</div>

<div class="title">

<h1>PAYMENT RECEIPT</h1>

</div>
<!-- =============================== -->
<!-- Receipt Information -->
<!-- =============================== -->

<div class="info-section">

    <div class="info-card">

        <div class="label">Receipt Number</div>

        <div class="value">
            <%= payment.receiptNumber %>
        </div>

    </div>

    <div class="info-card">

        <div class="label">Receipt Date</div>

        <div class="value">
            <%= new Date(payment.paymentDate).toLocaleDateString("en-IN") %>
        </div>

    </div>

    <div class="info-card">

        <div class="label">Payment Method</div>

        <div class="value">
            <%= payment.paymentMethod %>
        </div>

    </div>

    <div class="info-card">

        <div class="label">Status</div>

        <div class="status-paid">
            VERIFIED
        </div>

    </div>

</div>

<!-- =============================== -->
<!-- Customer + Payment -->
<!-- =============================== -->

<div class="grid">

    <!-- Customer -->

    <div class="card">

        <h2>Customer Details</h2>

        <table>

            <tr>

                <td>Name</td>

                <td>
                    <%= application.name %>
                </td>

            </tr>

            <tr>

                <td>Email</td>

                <td>
                    <%= application.email %>
                </td>

            </tr>

            <tr>

                <td>Mobile</td>

                <td>
                    <%= application.mobile %>
                </td>

            </tr>

        </table>

    </div>

    <!-- Payment -->

    <div class="card">

        <h2>Payment Details</h2>

        <table>

            <tr>

                <td>Amount</td>

                <td>

                    <strong class="amount">

                        ₹ <%= payment.amount %>

                    </strong>

                </td>

            </tr>

            <tr>

                <td>Transaction ID</td>

                <td>

                    <%= payment.transactionId || "N/A" %>

                </td>

            </tr>

            <tr>

                <td>Payment Date</td>

                <td>

                    <%= new Date(payment.paymentDate).toLocaleDateString("en-IN") %>

                </td>

            </tr>

        </table>

    </div>

</div>

<!-- ===================================== -->
<!-- Service Details -->
<!-- ===================================== -->

<div class="card full-card">

    <h2>Service Details</h2>

    <table>

        <tr>
            <td>Service Name</td>
            <td><%= application.service %></td>
        </tr>

        <tr>
            <td>Application ID</td>
            <td><%= application._id %></td>
        </tr>

        <tr>
            <td>Application Status</td>
            <td><%= application.status %></td>
        </tr>

        <tr>
            <td>Applied On</td>
            <td>
                <%= new Date(application.createdAt).toLocaleDateString("en-IN") %>
            </td>
        </tr>

    </table>

</div>

<!-- ===================================== -->
<!-- Verification Details -->
<!-- ===================================== -->

<div class="card full-card">

    <h2>Verification Details</h2>

    <table>

        <tr>
            <td>Verified By</td>
            <td>
                <%= payment.verifiedBy || "Administrator" %>
            </td>
        </tr>

        <tr>
            <td>Verified On</td>
            <td>
                <%= payment.verifiedAt
                ? new Date(payment.verifiedAt).toLocaleString("en-IN")
                : "-" %>
            </td>
        </tr>

        <tr>
            <td>Remarks</td>
            <td>
                <%= payment.remarks || "Payment verified successfully." %>
            </td>
        </tr>

    </table>

</div>

<!-- ===================================== -->
<!-- Total Paid -->
<!-- ===================================== -->

<div class="total-section">

    <p>Total Amount Paid</p>

    <h1>₹ <%= payment.amount %></h1>

</div>

<!-- ===================================== -->
<!-- Thank You -->
<!-- ===================================== -->

<div class="thank-you">

    <h2>Thank You!</h2>

    <p>

        Thank you for choosing

        <strong>
            <%= settings.businessName %>
        </strong>.

    </p>

    <p>

        Your payment has been received and verified successfully.

    </p>

</div>
<!-- ===================================== -->
<!-- Footer -->
<!-- ===================================== -->

<div class="footer">

    <div class="footer-grid">

        <div>

            <h3>Contact Us</h3>

            <p>
                📞 <%= settings.phone1 || "-" %>
            </p>

            <% if(settings.phone2){ %>
            <p>
                📞 <%= settings.phone2 %>
            </p>
            <% } %>

            <p>
                ✉ <%= settings.email || "-" %>
            </p>

        </div>

        <div>

            <h3>Office Address</h3>

            <p>
                <%= settings.address || "-" %>
            </p>

        </div>

        <div>

            <h3>Website</h3>

            <p>
                <%= settings.website || "-" %>
            </p>

            <% if(settings.officeHours){ %>

            <p>

                Office Hours

                <br>

                <%= settings.officeHours %>

            </p>

            <% } %>

        </div>

    </div>

    <div class="footer-note">

        This is a computer-generated payment receipt.

        <br>

        No signature is required.

    </div>

</div>

</div>

</body>

</html>